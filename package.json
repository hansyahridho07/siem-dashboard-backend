{
  "name": "siem-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend API for SIEM Dashboard integrating PostgreSQL and Elasticsearch",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/db.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/db.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/db.ts",
    "seed": "ts-node src/database/seed.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.2",
    "@types/swagger-ui-express": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
